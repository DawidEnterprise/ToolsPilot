# ToolsPilot environment variables
# Copy to .env.local and fill in values

# Azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=uploads
AZURE_FUNCTIONS_URL=
AZURE_APP_INSIGHTS_CONNECTION_STRING=

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-5256644690303885
# Optional: per-position ad slot IDs for granular reporting in AdSense dashboard.
# Create these in AdSense → Ads → By ad unit. Leave blank for auto mode.
NEXT_PUBLIC_ADSENSE_SLOT_TOOL_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_TOOL_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_IN_CONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_IN_FEED=
NEXT_PUBLIC_ADSENSE_SLOT_MULTIPLEX=
NEXT_PUBLIC_ADSENSE_SLOT_ANCHOR=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Site
NEXT_PUBLIC_SITE_URL=https://toolspilot.dev
NEXT_PUBLIC_SITE_NAME=ToolsPilot
